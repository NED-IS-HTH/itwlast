<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Food"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="24dp" />

        <!-- Food Name -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Food Name" android:textColor="#424242" android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etFoodName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Chicken Salad"
            android:inputType="textCapSentences"
            android:background="@drawable/input_background"
            android:padding="14dp"
            android:layout_marginBottom="16dp" />

        <!-- Meal Type -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Meal Type" android:textColor="#424242" android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <Spinner
            android:id="@+id/spinnerMealType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:padding="6dp"
            android:layout_marginBottom="16dp" />

        <!-- Calories -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Calories (kcal) *" android:textColor="#424242" android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etCalories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 350"
            android:inputType="number"
            android:background="@drawable/input_background"
            android:padding="14dp"
            android:layout_marginBottom="16dp" />

        <!-- Macros Row -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Macros (g) — Optional"
            android:textColor="#757575" android:textStyle="italic"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Carbs" android:textColor="#424242" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etCarbs" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="0"
                    android:inputType="numberDecimal" android:background="@drawable/input_background"
                    android:padding="12dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:layout_marginStart="6dp" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Protein" android:textColor="#424242" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etProtein" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="0"
                    android:inputType="numberDecimal" android:background="@drawable/input_background"
                    android:padding="12dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Fat" android:textColor="#424242" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etFat" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="0"
                    android:inputType="numberDecimal" android:background="@drawable/input_background"
                    android:padding="12dp"/>
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Add to Log"
            android:textSize="16sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Cancel"
            android:textSize="16sp"
            android:backgroundTint="#9E9E9E"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>
