<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello!"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#757575"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Logout"
                android:textSize="12sp"
                android:backgroundTint="#EF5350"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Streak -->
        <TextView
            android:id="@+id/tvStreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 0 day streak"
            android:textSize="14sp"
            android:textColor="#FF9800"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Calories card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories"
                    android:textSize="14sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvCaloriesConsumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"/>

                    <TextView
                        android:id="@+id/tvCaloriesTarget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 0 kcal"
                        android:textSize="16sp"
                        android:textColor="#757575"
                        android:layout_marginStart="8dp"/>

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/tvCaloriesRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 remaining"
                        android:textSize="13sp"
                        android:textColor="#4CAF50"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressCalories"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:progressTint="#4CAF50"
                    android:progressBackgroundTint="#E0E0E0"
                    android:max="2000"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Macros card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Macros"
                    android:textSize="14sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="12dp"/>

                <!-- Carbs -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                        android:text="Carbs" android:textColor="#212121" android:textSize="13sp"/>
                    <ProgressBar android:id="@+id/progressCarbs" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                        android:progressTint="#FF9800" android:progressBackgroundTint="#E0E0E0"/>
                    <TextView android:id="@+id/tvCarbs" android:layout_width="45dp"
                        android:layout_height="wrap_content" android:text="0g" android:textSize="12sp"
                        android:textColor="#FF9800" android:gravity="end"/>
                    <TextView android:id="@+id/tvCarbsTarget" android:layout_width="50dp"
                        android:layout_height="wrap_content" android:text="/ 0g" android:textSize="11sp"
                        android:textColor="#9E9E9E"/>
                </LinearLayout>

                <!-- Protein -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                        android:text="Protein" android:textColor="#212121" android:textSize="13sp"/>
                    <ProgressBar android:id="@+id/progressProtein" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                        android:progressTint="#F44336" android:progressBackgroundTint="#E0E0E0"/>
                    <TextView android:id="@+id/tvProtein" android:layout_width="45dp"
                        android:layout_height="wrap_content" android:text="0g" android:textSize="12sp"
                        android:textColor="#F44336" android:gravity="end"/>
                    <TextView android:id="@+id/tvProteinTarget" android:layout_width="50dp"
                        android:layout_height="wrap_content" android:text="/ 0g" android:textSize="11sp"
                        android:textColor="#9E9E9E"/>
                </LinearLayout>

                <!-- Fat -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                        android:text="Fat" android:textColor="#212121" android:textSize="13sp"/>
                    <ProgressBar android:id="@+id/progressFat" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                        android:progressTint="#9C27B0" android:progressBackgroundTint="#E0E0E0"/>
                    <TextView android:id="@+id/tvFat" android:layout_width="45dp"
                        android:layout_height="wrap_content" android:text="0g" android:textSize="12sp"
                        android:textColor="#9C27B0" android:gravity="end"/>
                    <TextView android:id="@+id/tvFatTarget" android:layout_width="50dp"
                        android:layout_height="wrap_content" android:text="/ 0g" android:textSize="11sp"
                        android:textColor="#9E9E9E"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Water card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💧 Water"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

                <ImageButton
                    android:id="@+id/btnRemoveWater"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_delete"
                    android:background="@drawable/circle_button"
                    android:backgroundTint="#E0E0E0"/>

                <TextView
                    android:id="@+id/tvWaterCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 8 glasses"
                    android:textSize="15sp"
                    android:textColor="#2196F3"
                    android:textStyle="bold"
                    android:layout_marginHorizontal="12dp"/>

                <ImageButton
                    android:id="@+id/btnAddWater"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_input_add"
                    android:background="@drawable/circle_button"
                    android:backgroundTint="#2196F3"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnAddFood"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="+ Add Food"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnHistory"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="History"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnProgress"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Progress"
                android:backgroundTint="#9C27B0"
                android:textColor="#FFFFFF"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/loadingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <!-- Today's Food Log -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Food Log"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerFoodLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</ScrollView>
